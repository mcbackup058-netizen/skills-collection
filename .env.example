# AI Step Flash 3.5 API Configuration
# Get your API key from: https://openrouter.ai/

# AI Step Flash 3.5 API Key (OpenRouter)
AI_STEP_FLASH_API_KEY=sk-or-v1-your-api-key-here

# Alternative: Set via environment variable
# export AI_STEP_FLASH_API_KEY=sk-or-v1-your-api-key-here

# Optional: Default model selection
# Options: step-ai/step-flash-3.5, step-ai/step-flash-3, step-ai/step-1x
DEFAULT_MODEL=step-ai/step-flash-3.5

# Optional: Debug mode
DEBUG=false

# Optional: Custom base URL (if using a proxy or alternative endpoint)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
